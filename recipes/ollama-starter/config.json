          "coder": {"backend": "ollama", "kwargs": {"host": "http://localhost:11434", "model_by_tier": {"large": "qwen2.5-coder:32b"}}},
          "hetero": {"backend": "ensemble", "kwargs": {
            "members": [
              {"backend": "ollama", "kwargs": {"host": "http://localhost:11434", "model_by_tier": {"large": "qwen2.5-coder:7b"}}},
              {"backend": "ollama", "kwargs": {"host": "http://localhost:11434", "model_by_tier": {"large": "llama3.1:8b"}}},
              {"backend": "ollama", "kwargs": {"host": "http://localhost:11434", "model_by_tier": {"large": "qwen2.5:14b"}}}
            ],
            "aggregator": {"backend": "ollama", "kwargs": {"host": "http://localhost:11434", "model_by_tier": {"large": "qwen2.5-coder:32b"}}}}}
        },
        "routing_table": {"qa": "tool", "code_implementation": "coder", "research": "hetero"},
        "default": "coder"
      }
    },
    "baseline(ollama-big)": {"backend": "ollama", "kwargs": {"host": "http://localhost:11434", "model_by_tier": {"large": "qwen2.5:72b"}}}
  }
